# =============================================================================
# Acadivo — Staging Environment Variables
# =============================================================================
# Copy this file to .env.staging and fill in real values
# =============================================================================

# ── Application ─────────────────────────────────────────────
NODE_ENV=staging
PORT=5000
API_URL=https://staging.acadivo.com/api
WEB_URL=https://staging.acadivo.com
APP_URL=https://staging.acadivo.com
SOCKET_URL=wss://staging.acadivo.com

# ── Database ─────────────────────────────────────────────────
# Use AWS RDS or DigitalOcean Managed DB for staging
DATABASE_URL=postgresql://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:5432/acadivo_staging?schema=public
REDIS_URL=redis://<REDIS_HOST>:6379

# ── PostgreSQL (for Docker Compose) ────────────────────────
POSTGRES_USER=<PLACEHOLDER>
POSTGRES_PASSWORD=<PLACEHOLDER>
POSTGRES_DB=acadivo_staging

# ── Authentication ─────────────────────────────────────────
JWT_SECRET=<PLACEHOLDER_GENERATE_STRONG_SECRET>
JWT_REFRESH_SECRET=<PLACEHOLDER_GENERATE_STRONG_SECRET>
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── SMS Providers (Pakistan Context) ───────────────────────
TWILIO_SID=<PLACEHOLDER>
TWILIO_TOKEN=<PLACEHOLDER>
SMS_JAZZ_API=<PLACEHOLDER>
SMS_ZONG_API=<PLACEHOLDER>

# ── Cloud Storage ──────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=<PLACEHOLDER>
CLOUDINARY_API_KEY=<PLACEHOLDER>
CLOUDINARY_SECRET=<PLACEHOLDER>

# ── Firebase / FCM ─────────────────────────────────────────
FIREBASE_PROJECT_ID=<PLACEHOLDER>
FIREBASE_PRIVATE_KEY=<PLACEHOLDER>
FIREBASE_CLIENT_EMAIL=<PLACEHOLDER>

# ── Email ──────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<PLACEHOLDER>
SMTP_PASS=<PLACEHOLDER>

# ── Rate Limiting ──────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── Logging ────────────────────────────────────────────────
LOG_LEVEL=debug

# ── Monitoring ─────────────────────────────────────────────
GRAFANA_ADMIN_USER=<PLACEHOLDER>
GRAFANA_ADMIN_PASSWORD=<PLACEHOLDER>

# ── SSL / Domain ───────────────────────────────────────────
CERTBOT_DOMAIN=staging.acadivo.com
CERTBOT_EMAIL=<PLACEHOLDER>

# ── AWS / S3 (for backups) ─────────────────────────────────
AWS_ACCESS_KEY_ID=<PLACEHOLDER>
AWS_SECRET_ACCESS_KEY=<PLACEHOLDER>
S3_BUCKET=acadivo-staging-backups
S3_REGION=ap-south-1

# ── GitHub Container Registry ──────────────────────────────
GITHUB_TOKEN=<PLACEHOLDER>

# ── Sentry (Error Tracking) ────────────────────────────────
SENTRY_DSN=<PLACEHOLDER>
SENTRY_ENVIRONMENT=staging
