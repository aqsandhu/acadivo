{
  "categories": [
    {
      "title": "## 🚀 Features",
      "labels": ["feature", "enhancement"]
    },
    {
      "title": "## 🐛 Bug Fixes",
      "labels": ["bug", "fix"]
    },
    {
      "title": "## 📝 Documentation",
      "labels": ["documentation", "docs"]
    },
    {
      "title": "## 🔧 Maintenance",
      "labels": ["chore", "refactor", "ci", "cd"]
    },
    {
      "title": "## 🛡️ Security",
      "labels": ["security"]
    }
  ],
  "template": "${{CHANGELOG}}

## Other Changes

${{UNCATEGORIZED}}",
  "pr_template": "- #${{NUMBER}} ${{TITLE}} (@${{AUTHOR}})",
  "empty_template": "- No changes",
  "ignore_labels": ["ignore", "duplicate"],
  "sort": "ASC"
}
