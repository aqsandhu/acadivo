# =============================================================================
# Acadivo — Environment Variables Template
# Copy this file to .env and fill in real values
# =============================================================================
# This template covers development, staging, and production contexts.
# For Pakistan deployment, use local SMS providers (Jazz, Zong, Ufone).
# =============================================================================

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  APPLICATION
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Environment mode: development | staging | production
NODE_ENV=development

# Service ports
PORT=5000

# Public URLs (used for CORS, redirects, emails)
API_URL=http://localhost:5000
WEB_URL=http://localhost:3000
APP_URL=http://localhost:3000
SOCKET_URL=ws://localhost:5001

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  DATABASE
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# PostgreSQL connection string
# Local: postgresql://USER:PASS@localhost:5432/DB?schema=public
# Production: postgresql://USER:PASS@rds-host:5432/DB?schema=public
DATABASE_URL=postgresql://acadivo:acadivo_password@localhost:5432/acadivo_db?schema=public

# Redis connection string
# Local: redis://localhost:6379
# Production: redis://elasticache-host:6379
REDIS_URL=redis://localhost:6379

# Docker Compose PostgreSQL overrides
POSTGRES_USER=acadivo
POSTGRES_PASSWORD=acadivo_password
POSTGRES_DB=acadivo_db

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  AUTHENTICATION
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# JWT secrets — generate strong keys:
#   openssl rand -base64 64
JWT_SECRET=change_me_super_secret_jwt_key_64chars_minimum
JWT_REFRESH_SECRET=change_me_super_secret_refresh_key_64chars_minimum

# Token expiry times
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  SMS PROVIDERS (Pakistan Context)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Twilio (for international)
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Jazz (Mobilink) Pakistan SMS API
SMS_JAZZ_API=https://jazzsms.com/api/send

# Zong Pakistan SMS API
SMS_ZONG_API=https://zongsms.com/api/send

# Ufone Pakistan SMS API (alternative)
SMS_UFONE_API=https://ufonesms.com/api/send

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  CLOUD STORAGE
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Cloudinary for images/videos
CLOUDINARY_CLOUD_NAME=acadivo-cloud
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxx

# AWS S3 for file storage (alternatives: MinIO, DigitalOcean Spaces)
S3_BUCKET=acadivo-files
S3_REGION=ap-south-1
S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  FIREBASE / FCM (Push Notifications)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

FIREBASE_PROJECT_ID=acadivo-firebase-project
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nxxx\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@acadivo.iam.gserviceaccount.com

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  EMAIL (SMTP)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@acadivo.com
SMTP_PASS=xxxxxxxxxxxxxxxx

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  RATE LIMITING
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  LOGGING
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Levels: debug, info, warn, error
LOG_LEVEL=info

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  MONITORING
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_now

# Sentry error tracking
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  SSL / CERTBOT
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

CERTBOT_DOMAIN=acadivo.com
CERTBOT_EMAIL=admin@acadivo.com

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  PAYMENTS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Stripe (for online payments)
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  ANALYTICS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GTM_ID=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  DEVELOPMENT OVERRIDES
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Prisma query logging (dev only)
PRISMA_LOG_LEVEL=query,info,warn,error

# Disable telemetry
TURBO_TELEMETRY_DISABLED=1
NEXT_TELEMETRY_DISABLED=1
