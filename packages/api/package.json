{
  "name": "@acadivo/api",
  "version": "0.1.0",
  "private": true,
  "description": "Acadivo REST API — Node.js + Express + Prisma",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "ts-node prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:format": "prisma format"
  },
  "dependencies": {
    "express": "^4.19.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "compression": "^1.7.4",
    "dotenv": "^16.4.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "express-validator": "^7.0.0",
    "prisma": "^5.12.0",
    "@prisma/client": "^5.12.0",
    "socket.io": "^4.7.0",
    "ioredis": "^5.4.0",
    "multer": "^1.4.5-lts.1",
    "zod": "^3.22.0",
    "cloudinary": "^2.1.0",
    "nodemailer": "^6.9.0",
    "twilio": "^5.0.0",
    "express-rate-limit": "^7.2.0",
    "winston": "^3.13.0",
    "joi": "^17.12.0",
    "speakeasy": "^2.0.0",
    "qrcode": "^1.5.3",
    "puppeteer": "^22.0.0",
    "csv-parse": "^5.5.0",
    "xlsx": "^0.18.5",
    "@acadivo/shared": "*"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "ts-node": "^10.9.0",
    "nodemon": "^3.1.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "@types/compression": "^1.7.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/passport": "^1.0.16",
    "@types/passport-jwt": "^4.0.1",
    "@types/multer": "^1.4.11",
    "@types/nodemailer": "^6.4.14",
    "@types/node": "^20.12.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.12",
    "ts-jest": "^29.1.0",
    "supertest": "^6.3.4",
    "@types/supertest": "^6.0.2",
    "eslint": "^8.57.0"
  }
}
