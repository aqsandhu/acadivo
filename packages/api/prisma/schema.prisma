// Acadivo Multi-Tenant EdTech Platform — Prisma Schema
// Pakistani Schools/Colleges Management System
// All models include tenantId for row-level security isolation

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════

enum TenantType {
  SCHOOL
  COLLEGE
  UNIVERSITY
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum SubscriptionPlan {
  FREE
  BASIC
  STANDARD
  PREMIUM
}

enum UserRole {
  SUPER_ADMIN
  PRINCIPAL
  ADMIN
  TEACHER
  STUDENT
  PARENT
}

enum UserGender {
  MALE
  FEMALE
  OTHER
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  GRADUATED
  TRANSFERRED
  SUSPENDED
}

enum ParentRelation {
  FATHER
  MOTHER
  GUARDIAN
  SIBLING
  OTHER
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  LEAVE
  HALF_DAY
  EXCUSED
}

enum AttendanceMethod {
  MANUAL
  BIOMETRIC
  QR
  APP
}

enum HomeworkSubmissionStatus {
  PENDING
  SUBMITTED
  LATE
  GRADED
}

enum HomeworkStatus {
  PENDING
  ACTIVE
  CLOSED
  ARCHIVED
}

enum ExamType {
  QUIZ
  MIDTERM
  FINAL
  ASSIGNMENT
  PROJECT
  PRACTICAL
  ORAL
}

enum ExamStatus {
  SCHEDULED
  ONGOING
  COMPLETED
  CANCELLED
}

enum ResultTerm {
  FIRST
  SECOND
  THIRD
  FINAL
}

enum ResultStatus {
  PASS
  FAIL
  PROMOTED
  ABSENT
  INCOMPLETE
}

enum ReportRequestStatus {
  PENDING
  COMPLETED
  REJECTED
}

enum ReportRequestType {
  PROGRESS
  ATTENDANCE
  BEHAVIOR
  COMPREHENSIVE
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  VOICE
  VIDEO
  ANNOUNCEMENT
}

enum ConversationType {
  DIRECT
  GROUP
  CLASS
  SCHOOL
}

enum NotificationType {
  ANNOUNCEMENT
  MESSAGE
  REPORT_READY
  FEE_DUE
  ATTENDANCE_ALERT
  HOMEWORK
  RESULT
  TIMETABLE_CHANGE
  ADVERTISEMENT
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum NotificationCategory {
  ATTENDANCE
  HOMEWORK
  FEE
  RESULT
  MESSAGE
  ANNOUNCEMENT
  SYSTEM
  EVENT
}

enum AnnouncementPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum AnnouncementTargetAudience {
  ALL
  TEACHERS
  STUDENTS
  PARENTS
  ADMIN
  CLASS
}

enum FeeType {
  TUITION
  ADMISSION
  EXAM
  LAB
  SPORTS
  LIBRARY
  TRANSPORT
  MISC
}

enum FeeFrequency {
  MONTHLY
  QUARTERLY
  SEMESTERLY
  YEARLY
  ONE_TIME
}

enum FeeStatus {
  PAID
  UNPAID
  PARTIAL
  WAIVED
  OVERDUE
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  EASYPAYSA
  JAZZCASH
  CHEQUE
  CARD
  ONLINE
}

enum AdTargetAudience {
  ALL
  STUDENTS
  PARENTS
  TEACHERS
  PRINCIPALS
  ADMIN
}

enum AdStatus {
  ACTIVE
  PENDING
  EXPIRED
  PAUSED
  ARCHIVED
  DRAFT
}

enum AdImpressionType {
  VIEW
  CLICK
}

enum AdPlacement {
  DASHBOARD
  LOGIN
  SIDEBAR
  BANNER
  POPUP
}

enum SchoolSubscriptionStatus {
  ACTIVE
  TRIAL
  EXPIRED
  CANCELLED
}

enum LoginStatus {
  SUCCESS
  FAILED
}

enum SettingCategory {
  GENERAL
  ACADEMIC
  FEE
  COMMUNICATION
  NOTIFICATION
}

enum TeacherStatus {
  ACTIVE
  ON_LEAVE
  RESIGNED
  SUSPENDED
}

enum AuditSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  IMPORT
  APPROVE
  REJECT
  SUSPEND
  ACTIVATE
}

// ═══════════════════════════════════════════════════
// 1. TENANT (School / Institute)
// ═══════════════════════════════════════════════════

model Tenant {
  id                  String         @id @default(uuid())
  name                String
  code                String         @unique
  type                TenantType
  city                String
  address             String         @db.Text
  phone               String
  email               String
  logo                String?
  status              TenantStatus   @default(PENDING)
  subscriptionPlan    SubscriptionPlan @default(FREE)
  subscriptionExpiry    DateTime?
  maxTeachers         Int            @default(10)
  maxStudents         Int            @default(100)
  createdBy           String
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  // ── Relations ──
  users                User[]
  principals           Principal[]
  admins               SchoolAdmin[]
  teachers             Teacher[]
  students             Student[]
  parents              Parent[]
  studentParents       StudentParent[]
  classes              Class[]
  sections             Section[]
  subjects             Subject[]
  teacherSubjects      TeacherSubject[]
  classSchedules       ClassSchedule[]
  attendances          Attendance[]
  attendanceAlerts     AttendanceAlert[]
  homeworks            Homework[]
  homeworkSubmissions  HomeworkSubmission[]
  marks                Mark[]
  exams                Exam[]
  results              Result[]
  resultDetails        ResultDetail[]
  reportRequests       ReportRequest[]
  messages             Message[]
  conversations        Conversation[]
  conversationMembers  ConversationMember[]
  messageReadReceipts  MessageReadReceipt[]
  notifications        Notification[]
  notificationPreferences NotificationPreference[]
  announcements        Announcement[]
  feeStructures        FeeStructure[]
  feeRecords           FeeRecord[]
  installments         Installment[]
  feeDiscounts         FeeDiscount[]
  adImpressions        AdImpression[]
  schoolSubscriptions  SchoolSubscription[]
  auditLogs            AuditLog[]
  gradingSchemes       GradingScheme[]
  settings             Setting[]
  userPreferences      UserPreference[]

  @@index([code])
  @@index([status])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════
// 2. USER (Base table — all roles)
// ═══════════════════════════════════════════════════

model User {
  id                  String    @id @default(uuid())
  uniqueId            String    @unique
  email               String
  passwordHash        String
  role                UserRole
  tenantId            String
  firstName           String
  lastName            String
  phone               String
  cnic                String?
  avatar              String?
  gender              UserGender?
  dateOfBirth         DateTime?
  address             String?   @db.Text
  city                String?
  isActive            Boolean   @default(true)
  isVerified          Boolean   @default(false)
  twoFactorEnabled    Boolean   @default(false)
  twoFactorSecret     String?
  lastLoginAt         DateTime?
  loginAttempts       Int       @default(0)
  lockUntil           DateTime?
  passwordChangedAt   DateTime?
  language            String    @default("en")
  darkMode            Boolean   @default(false)
  soundEnabled        Boolean   @default(true)
  notificationPreferences Json? // backward-compat: JSON blob of preferences
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // ── Role-specific profiles ──
  principal     Principal?
  admin         SchoolAdmin?
  teacher       Teacher?
  student       Student?
  parent        Parent?

  // ── Activity Relations ──
  tenant              Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sentMessages        Message[]           @relation("SentMessages")
  receivedMessages    Message[]           @relation("ReceivedMessages")
  notifications       Notification[]        @relation("UserNotifications")
  notificationsSent   Notification[]          @relation("SentNotifications")
  loginHistory        LoginHistory[]
  postedAnnouncements Announcement[]          @relation("PostedBy")
  gradedSubmissions   HomeworkSubmission[]  @relation("GradedBy")
  resultsGenerated    Result[]              @relation("GeneratedBy")
  reportRequestsAsTeacher ReportRequest[]   @relation("ReportTeacher")
  adsCreated          Advertisement[]
  adImpressions       AdImpression[]
  auditLogs           AuditLog[]
  conversations       ConversationMember[]
  messageReadReceipts MessageReadReceipt[]
  notificationPrefs   NotificationPreference[]
  userPreferences     UserPreference[]

  @@unique([email, tenantId])
  @@index([tenantId])
  @@index([role])
  @@index([tenantId, role])
  @@index([uniqueId])
  @@index([isActive])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════
// 3. PRINCIPAL
// ═══════════════════════════════════════════════════

model Principal {
  userId          String    @id
  tenantId        String
  qualifications  String?   @db.Text
  experience      Int?
  joiningDate     DateTime?
  bio             String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ═══════════════════════════════════════════════════
// 4. SCHOOL ADMIN
// ═══════════════════════════════════════════════════

model SchoolAdmin {
  userId        String    @id
  tenantId      String
  department    String?
  permissions   Json?     // JSON array of allowed action strings
  joiningDate   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ═══════════════════════════════════════════════════
// 5. TEACHER
// ═══════════════════════════════════════════════════

model Teacher {
  userId            String   @id
  tenantId          String
  employeeId        String?
  qualifications    String?  @db.Text
  specialization    String?
  experience        Int?
  salary            Decimal? @db.Decimal(10, 2)
  joiningDate       DateTime?
  bio               String?  @db.Text
  isClassTeacher    Boolean  @default(false)
  assignedClassId   String?   @unique
  assignedSectionId String?
  status            TeacherStatus @default(ACTIVE)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedClass     Class?          @relation("ClassTeacher", fields: [assignedClassId], references: [id], onDelete: SetNull)
  assignedSection   Section?        @relation("SectionTeacher", fields: [assignedSectionId], references: [id], onDelete: SetNull)
  subjects          TeacherSubject[]
  classSchedules    ClassSchedule[]
  attendancesMarked Attendance[]    @relation("AttendanceMarkedBy")
  homeworks         Homework[]
  marks             Mark[]          @relation("TeacherMarks")

  @@index([tenantId])
  @@index([assignedClassId])
  @@index([assignedSectionId])
  @@index([status])
  @@index([employeeId])
}

// ═══════════════════════════════════════════════════
// 6. STUDENT
// ═══════════════════════════════════════════════════

model Student {
  userId            String        @id
  tenantId          String
  rollNumber        String
  admissionNumber   String?
  classId           String
  sectionId         String
  admissionDate     DateTime      @default(now())
  guardianName      String
  guardianPhone     String
  guardianRelation  String
  guardianCNIC      String?
  bloodGroup        String?
  medicalNotes      String?       @db.Text
  status            StudentStatus @default(ACTIVE)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user                User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant              Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  class               Class                 @relation(fields: [classId], references: [id], onDelete: Cascade)
  section             Section               @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  parentLinks         StudentParent[]
  attendances         Attendance[]
  attendanceAlerts    AttendanceAlert[]
  homeworkSubmissions HomeworkSubmission[]
  marks               Mark[]
  reports             Result[]
  feeRecords          FeeRecord[]
  installments        Installment[]
  feeDiscounts        FeeDiscount[]
  reportRequests      ReportRequest[]
  adImpressions       AdImpression[]
  conversationMembers ConversationMember[]
  messageReadReceipts MessageReadReceipt[]

  @@unique([rollNumber, tenantId])
  @@index([tenantId])
  @@index([classId])
  @@index([tenantId, classId])
  @@index([sectionId])
  @@index([status])
  @@index([admissionNumber])
}

// ═══════════════════════════════════════════════════
// 7. PARENT
// ═══════════════════════════════════════════════════

model Parent {
  userId            String   @id
  tenantId          String
  occupation        String?
  emergencyContact  String?
  emergencyRelation String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  children        StudentParent[]
  reportRequests  ReportRequest[]
  conversationMembers ConversationMember[]

  @@index([tenantId])
}

// ═══════════════════════════════════════════════════
// 8. STUDENT PARENT (junction)
// ═══════════════════════════════════════════════════

model StudentParent {
  id          String         @id @default(uuid())
  studentId   String
  parentId    String
  relation    ParentRelation
  isPrimary   Boolean        @default(false)
  canPickup   Boolean        @default(true)
  isEmergencyContact Boolean @default(false)
  tenantId    String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  student  Student @relation(fields: [studentId], references: [userId], onDelete: Cascade)
  parent   Parent  @relation(fields: [parentId], references: [userId], onDelete: Cascade)
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([studentId, parentId])
  @@index([tenantId])
  @@index([studentId])
  @@index([parentId])
}

// ═══════════════════════════════════════════════════
// 9. CLASS
// ═══════════════════════════════════════════════════

model Class {
  id              String   @id @default(uuid())
  tenantId        String
  name            String
  grade           String   // e.g. "10", "11", "12"
  roomNumber      String?
  capacity        Int      @default(30)
  academicYear    String
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sections        Section[]
  students        Student[]
  classTeacher    Teacher?        @relation("ClassTeacher")
  subjects        TeacherSubject[]
  schedules       ClassSchedule[]
  attendances     Attendance[]
  homeworks       Homework[]
  marks           Mark[]
  results         Result[]
  feeStructures   FeeStructure[]
  announcements   Announcement[]  @relation("TargetClass")
  exams           Exam[]
  conversations   Conversation[]

  @@index([tenantId])
  @@index([academicYear])
  @@index([isActive])
}

// ═══════════════════════════════════════════════════
// 10. SECTION
// ═══════════════════════════════════════════════════

model Section {
  id          String   @id @default(uuid())
  tenantId    String
  classId     String
  name        String   // e.g. "A", "B", "C"
  capacity    Int      @default(30)
  roomNumber  String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  class           Class           @relation(fields: [classId], references: [id], onDelete: Cascade)
  students        Student[]
  schedules       ClassSchedule[]
  attendances     Attendance[]
  homeworks       Homework[]
  marks           Mark[]
  results         Result[]
  teacherSubjects TeacherSubject[]
  sectionTeachers Teacher[]       @relation("SectionTeacher")

  @@unique([classId, name])
  @@index([tenantId])
  @@index([classId])
}

// ═══════════════════════════════════════════════════
// 11. SUBJECT
// ═══════════════════════════════════════════════════

model Subject {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  code        String
  description String?  @db.Text
  creditHours Int      @default(3)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teachers        TeacherSubject[]
  schedules       ClassSchedule[]
  marks           Mark[]
  homeworks       Homework[]
  resultDetails   ResultDetail[]
  exams           Exam[]

  @@unique([code, tenantId])
  @@index([tenantId])
  @@index([isActive])
}

// ═══════════════════════════════════════════════════
// 12. TEACHER SUBJECT (junction)
// ═══════════════════════════════════════════════════

model TeacherSubject {
  id            String   @id @default(uuid())
  teacherId     String
  subjectId     String
  classId       String
  sectionId     String
  tenantId      String
  academicYear  String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  teacher Teacher @relation(fields: [teacherId], references: [userId], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([teacherId, subjectId, classId, sectionId, academicYear])
  @@index([tenantId])
  @@index([teacherId])
  @@index([subjectId])
  @@index([classId])
  @@index([sectionId])
}

// ═══════════════════════════════════════════════════
// 13. CLASS SCHEDULE (Timetable)
// ═══════════════════════════════════════════════════

model ClassSchedule {
  id            String   @id @default(uuid())
  tenantId      String
  classId       String
  sectionId     String
  subjectId     String
  teacherId     String
  dayOfWeek     Int      // 0=Sunday, 6=Saturday
  periodNumber  Int
  startTime     String   // "HH:MM" format
  endTime       String   // "HH:MM" format
  roomNumber    String?
  academicYear  String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  class    Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  section  Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subject  Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher  Teacher @relation(fields: [teacherId], references: [userId], onDelete: Cascade)

  @@unique([classId, sectionId, dayOfWeek, periodNumber, academicYear])
  @@index([tenantId])
  @@index([classId])
  @@index([sectionId])
  @@index([teacherId])
  @@index([dayOfWeek])
  @@index([academicYear])
}

// ═══════════════════════════════════════════════════
// 14. ATTENDANCE
// ═══════════════════════════════════════════════════

model Attendance {
  id            String           @id @default(uuid())
  tenantId      String
  studentId     String
  classId       String
  sectionId     String
  date          DateTime
  status        AttendanceStatus
  markedBy      String
  periodNumber  Int?
  remarks       String?          @db.Text
  checkIn       DateTime?
  checkOut      DateTime?
  method        AttendanceMethod @default(MANUAL)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  tenant          Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student         Student @relation(fields: [studentId], references: [userId], onDelete: SetNull)
  class           Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  section         Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  markedByTeacher Teacher @relation("AttendanceMarkedBy", fields: [markedBy], references: [userId], onDelete: Cascade)

  @@unique([studentId, date, periodNumber])
  @@index([tenantId])
  @@index([studentId])
  @@index([classId])
  @@index([sectionId])
  @@index([date])
  @@index([status])
  @@index([markedBy])
  @@index([method])
}

// ═══════════════════════════════════════════════════
// 14b. ATTENDANCE ALERT (3-consecutive-absence auto-alert)
// ═══════════════════════════════════════════════════

model AttendanceAlert {
  id            String   @id @default(uuid())
  tenantId      String
  studentId     String
  consecutiveDays Int    @default(3)
  startDate     DateTime
  endDate       DateTime?
  isResolved    Boolean  @default(false)
  resolvedAt    DateTime?
  resolvedBy    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student  Student @relation(fields: [studentId], references: [userId], onDelete: SetNull)

  @@index([tenantId])
  @@index([studentId])
  @@index([isResolved])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════
// 15. HOMEWORK
// ═══════════════════════════════════════════════════

model Homework {
  id            String   @id @default(uuid())
  tenantId      String
  teacherId     String
  classId       String
  sectionId     String
  subjectId     String
  title         String
  description   String   @db.Text
  attachments   Json?    // JSON array of file objects
  dueDate       DateTime
  maxMarks      Int?
  isActive      Boolean  @default(true)
  status        HomeworkStatus @default(ACTIVE)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teacher     Teacher             @relation(fields: [teacherId], references: [userId], onDelete: Cascade)
  class       Class               @relation(fields: [classId], references: [id], onDelete: Cascade)
  section     Section             @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subject     Subject             @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  submissions HomeworkSubmission[]

  @@index([tenantId])
  @@index([teacherId])
  @@index([classId])
  @@index([sectionId])
  @@index([subjectId])
  @@index([dueDate])
  @@index([status])
}

// ═══════════════════════════════════════════════════
// 16. HOMEWORK SUBMISSION
// ═══════════════════════════════════════════════════

model HomeworkSubmission {
  id              String                   @id @default(uuid())
  tenantId        String
  homeworkId      String
  studentId       String
  submissionText  String?                  @db.Text
  attachments     Json?                    // JSON array of file objects
  submittedAt     DateTime?
  status          HomeworkSubmissionStatus @default(PENDING)
  marks           Int?
  feedback        String?                  @db.Text
  gradedBy        String?
  gradedAt        DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  homework        Homework        @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  student         Student         @relation(fields: [studentId], references: [userId], onDelete: SetNull)
  gradedByTeacher User?           @relation("GradedBy", fields: [gradedBy], references: [id], onDelete: SetNull)

  @@unique([homeworkId, studentId])
  @@index([tenantId])
  @@index([homeworkId])
  @@index([studentId])
  @@index([status])
  @@index([gradedBy])
}

// ═══════════════════════════════════════════════════
// 17. EXAM (Exam scheduling)
// ═══════════════════════════════════════════════════

model Exam {
  id            String     @id @default(uuid())
  tenantId      String
  name          String
  type          ExamType
  classId       String
  subjectId     String?
  startDate     DateTime
  endDate       DateTime?
  maxMarks      Int
  passingMarks  Int        @default(33)
  weightage     Float?     // percentage weight in final result
  status        ExamStatus @default(SCHEDULED)
  academicYear  String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  class    Class  @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject  Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  marks    Mark[]

  @@index([tenantId])
  @@index([classId])
  @@index([subjectId])
  @@index([status])
  @@index([startDate])
  @@index([academicYear])
}

// ═══════════════════════════════════════════════════
// 18. MARK (Subject-wise marks/assessments)
// ═══════════════════════════════════════════════════

model Mark {
  id            String   @id @default(uuid())
  tenantId      String
  studentId     String
  subjectId     String
  classId       String
  sectionId     String
  teacherId     String
  examId        String?
  gradingSchemeId String?
  examType      ExamType
  totalMarks    Int
  obtainedMarks Int
  percentage    Float
  grade         String
  remarks       String?  @db.Text
  academicYear  String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student       Student       @relation(fields: [studentId], references: [userId], onDelete: SetNull)
  subject       Subject       @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  class         Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  section       Section       @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  teacher       Teacher       @relation("TeacherMarks", fields: [teacherId], references: [userId], onDelete: Cascade)
  exam          Exam?         @relation(fields: [examId], references: [id], onDelete: SetNull)
  gradingScheme GradingScheme? @relation(fields: [gradingSchemeId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([studentId])
  @@index([subjectId])
  @@index([classId])
  @@index([sectionId])
  @@index([teacherId])
  @@index([examId])
  @@index([gradingSchemeId])
  @@index([examType])
  @@index([academicYear])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════
// 19. RESULT (Compiled final result)
// ═══════════════════════════════════════════════════

model Result {
  id                String       @id @default(uuid())
  tenantId          String
  studentId         String
  classId           String
  sectionId         String
  academicYear      String
  term              ResultTerm
  totalMarks        Int
  obtainedMarks     Int
  percentage        Float
  grade             String
  rank              Int?
  status            ResultStatus
  teacherRemarks    String?      @db.Text
  principalRemarks  String?      @db.Text
  isPublished       Boolean      @default(false)
  publishedAt       DateTime?
  generatedAt       DateTime     @default(now())
  generatedBy       String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student         Student        @relation(fields: [studentId], references: [userId], onDelete: SetNull)
  class           Class          @relation(fields: [classId], references: [id], onDelete: Cascade)
  section         Section        @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  generatedByUser User?          @relation("GeneratedBy", fields: [generatedBy], references: [id], onDelete: SetNull)
  resultDetails   ResultDetail[]

  @@unique([studentId, academicYear, term])
  @@index([tenantId])
  @@index([studentId])
  @@index([classId])
  @@index([sectionId])
  @@index([academicYear])
  @@index([term])
  @@index([status])
  @@index([isPublished])
}

// ═══════════════════════════════════════════════════
// 20. RESULT DETAIL (Individual subject results)
// ═══════════════════════════════════════════════════

model ResultDetail {
  id            String   @id @default(uuid())
  tenantId      String
  resultId      String
  subjectId     String
  totalMarks    Int
  obtainedMarks Int
  grade         String
  remarks       String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  result   Result  @relation(fields: [resultId], references: [id], onDelete: Cascade)
  subject  Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([resultId])
  @@index([subjectId])
}

// ═══════════════════════════════════════════════════
// 21. REPORT REQUEST (Parent requests report from teacher)
// ═══════════════════════════════════════════════════

model ReportRequest {
  id              String               @id @default(uuid())
  tenantId        String
  parentId        String
  studentId       String
  teacherId       String
  status          ReportRequestStatus  @default(PENDING)
  requestedAt     DateTime             @default(now())
  completedAt     DateTime?
  reportType      ReportRequestType
  teacherRemarks  String?              @db.Text
  pdfUrl          String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   Parent  @relation(fields: [parentId], references: [userId], onDelete: Cascade)
  student  Student @relation(fields: [studentId], references: [userId], onDelete: Cascade)
  teacher  User    @relation("ReportTeacher", fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([parentId])
  @@index([studentId])
  @@index([teacherId])
  @@index([status])
  @@index([requestedAt])
}

// ═══════════════════════════════════════════════════
// 22. CONVERSATION (Grouped messaging)
// ═══════════════════════════════════════════════════

model Conversation {
  id                String           @id @default(uuid())
  tenantId          String
  type              ConversationType @default(DIRECT)
  title             String?
  classId           String?
  lastMessageAt     DateTime?
  lastMessagePreview String?         @db.Text
  isActive          Boolean          @default(true)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  tenant    Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  class     Class?               @relation(fields: [classId], references: [id], onDelete: SetNull)
  members   ConversationMember[]
  messages  Message[]

  @@index([tenantId])
  @@index([type])
  @@index([classId])
  @@index([lastMessageAt])
  @@index([isActive])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════
// 22b. CONVERSATION MEMBER
// ═══════════════════════════════════════════════════

model ConversationMember {
  id              String   @id @default(uuid())
  tenantId        String
  conversationId String
  userId          String?
  studentId       String?
  parentId        String?
  role            String   @default("MEMBER") // ADMIN, MEMBER
  joinedAt        DateTime @default(now())
  leftAt          DateTime?
  unreadCount     Int      @default(0)
  lastReadAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  student      Student?     @relation(fields: [studentId], references: [userId], onDelete: SetNull)
  parent       Parent?      @relation(fields: [parentId], references: [userId], onDelete: SetNull)

  @@unique([conversationId, userId])
  @@unique([conversationId, studentId])
  @@unique([conversationId, parentId])
  @@index([tenantId])
  @@index([conversationId])
  @@index([userId])
  @@index([studentId])
  @@index([parentId])
}

// ═══════════════════════════════════════════════════
// 23. MESSAGE (Chat / Messaging)
// ═══════════════════════════════════════════════════

model Message {
  id              String      @id @default(uuid())
  tenantId        String
  senderId        String
  receiverId      String?
  conversationId  String?
  content         String      @db.Text
  attachments     Json?       // JSON array of file objects
  isRead          Boolean     @default(false)
  readAt          DateTime?
  messageType     MessageType @default(TEXT)
  replyToId       String?
  isDeleted       Boolean     @default(false)
  deletedAt       DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sender       User              @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver     User?             @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: SetNull)
  conversation Conversation?     @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  replyTo      Message?          @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies      Message[]         @relation("MessageReplies")
  readReceipts MessageReadReceipt[]

  @@index([tenantId])
  @@index([senderId])
  @@index([receiverId])
  @@index([conversationId])
  @@index([isRead])
  @@index([isDeleted])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════
// 23b. MESSAGE READ RECEIPT
// ═══════════════════════════════════════════════════

model MessageReadReceipt {
  id            String   @id @default(uuid())
  tenantId      String
  messageId     String
  userId        String?
  studentId     String?
  readAt        DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  message  Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user     User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  student  Student? @relation(fields: [studentId], references: [userId], onDelete: SetNull)

  @@unique([messageId, userId])
  @@unique([messageId, studentId])
  @@index([tenantId])
  @@index([messageId])
  @@index([userId])
  @@index([studentId])
  @@index([readAt])
}

// ═══════════════════════════════════════════════════
// 24. NOTIFICATION
// ═══════════════════════════════════════════════════

model Notification {
  id            String           @id @default(uuid())
  tenantId      String
  userId        String
  title         String
  body          String           @db.Text
  type          NotificationType
  priority      NotificationPriority @default(NORMAL)
  isRead        Boolean          @default(false)
  readAt        DateTime?
  data          Json?            // JSON metadata
  senderId      String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  sender User?  @relation("SentNotifications", fields: [senderId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([userId])
  @@index([type])
  @@index([priority])
  @@index([isRead])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════
// 24b. NOTIFICATION PREFERENCE (per-user notification settings)
// ═══════════════════════════════════════════════════

model NotificationPreference {
  id                String   @id @default(uuid())
  tenantId          String
  userId            String
  category          NotificationCategory
  pushEnabled       Boolean  @default(true)
  emailEnabled      Boolean  @default(true)
  smsEnabled        Boolean  @default(false)
  inAppEnabled      Boolean  @default(true)
  quietHoursStart   String?  // "HH:mm"
  quietHoursEnd     String?  // "HH:mm"
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@index([tenantId])
  @@index([userId])
  @@index([category])
}

// ═══════════════════════════════════════════════════
// 25. USER PREFERENCE (structured user preferences)
// ═══════════════════════════════════════════════════

model UserPreference {
  id              String   @id @default(uuid())
  tenantId        String
  userId          String
  key             String
  value           String   @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([tenantId])
  @@index([userId])
  @@index([key])
}

// ═══════════════════════════════════════════════════
// 26. ANNOUNCEMENT (Noticeboard)
// ═══════════════════════════════════════════════════

model Announcement {
  id                String                     @id @default(uuid())
  tenantId          String
  postedBy          String
  title             String
  content           String                     @db.Text
  attachments       Json?                      // JSON array of file objects
  priority          AnnouncementPriority       @default(NORMAL)
  targetAudience    AnnouncementTargetAudience @default(ALL)
  targetClassId     String?
  targetSectionId   String?
  isPinned          Boolean                    @default(false)
  expiresAt         DateTime?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  tenant      Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  postedByUser User   @relation("PostedBy", fields: [postedBy], references: [id], onDelete: Cascade)
  targetClass Class?  @relation("TargetClass", fields: [targetClassId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([postedBy])
  @@index([priority])
  @@index([targetAudience])
  @@index([targetClassId])
  @@index([isPinned])
  @@index([expiresAt])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════
// 27. FEE STRUCTURE
// ═══════════════════════════════════════════════════

model FeeStructure {
  id            String       @id @default(uuid())
  tenantId      String
  classId       String?
  feeType       FeeType
  amount        Decimal      @db.Decimal(10, 2)
  frequency     FeeFrequency
  dueDay        Int?
  lateFeePerDay Decimal?     @db.Decimal(10, 2)
  isActive      Boolean      @default(true)
  academicYear  String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  class       Class?      @relation(fields: [classId], references: [id], onDelete: SetNull)
  feeRecords  FeeRecord[]
  installments Installment[]
  feeDiscounts FeeDiscount[]

  @@index([tenantId])
  @@index([classId])
  @@index([feeType])
  @@index([academicYear])
  @@index([isActive])
}

// ═══════════════════════════════════════════════════
// 28. FEE RECORD
// ═══════════════════════════════════════════════════

model FeeRecord {
  id              String        @id @default(uuid())
  tenantId        String
  studentId       String
  feeStructureId  String
  amount          Decimal       @db.Decimal(10, 2)
  discountAmount  Decimal?      @db.Decimal(10, 2)
  discountReason  String?
  fineAmount      Decimal?      @db.Decimal(10, 2)
  fineReason      String?
  finalAmount     Decimal       @db.Decimal(10, 2)
  paidAmount      Decimal       @db.Decimal(10, 2)
  balance         Decimal       @db.Decimal(10, 2)
  status          FeeStatus     @default(UNPAID)
  dueDate         DateTime
  paidDate        DateTime?
  paymentMethod   PaymentMethod?
  transactionId   String?
  receiptNumber   String?
  remarks         String?       @db.Text
  notifiedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student      Student      @relation(fields: [studentId], references: [userId], onDelete: SetNull)
  feeStructure FeeStructure @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)
  installments Installment[]

  @@index([tenantId])
  @@index([studentId])
  @@index([studentId, status])
  @@index([feeStructureId])
  @@index([status])
  @@index([dueDate])
  @@index([paidDate])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════
// 28b. INSTALLMENT (fee installment tracking)
// ═══════════════════════════════════════════════════

model Installment {
  id            String        @id @default(uuid())
  tenantId      String
  feeRecordId   String
  studentId     String?
  feeStructureId String?
  amount        Decimal       @db.Decimal(10, 2)
  paidAmount    Decimal       @db.Decimal(10, 2) @default(0)
  dueDate       DateTime
  paidDate      DateTime?
  status        FeeStatus     @default(UNPAID)
  paymentMethod PaymentMethod?
  transactionId String?
  receiptNumber String?
  remarks       String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  feeRecord    FeeRecord    @relation(fields: [feeRecordId], references: [id], onDelete: Cascade)
  feeStructure FeeStructure? @relation(fields: [feeStructureId], references: [id], onDelete: SetNull)
  student      Student?     @relation(fields: [studentId], references: [userId], onDelete: SetNull)

  @@index([tenantId])
  @@index([feeRecordId])
  @@index([studentId])
  @@index([feeStructureId])
  @@index([status])
  @@index([dueDate])
  @@index([paidDate])
}

// ═══════════════════════════════════════════════════
// 28c. FEE DISCOUNT (discount records)
// ═══════════════════════════════════════════════════

model FeeDiscount {
  id              String   @id @default(uuid())
  tenantId        String
  studentId       String
  feeStructureId  String?
  amount          Decimal  @db.Decimal(10, 2)
  percentage      Float?
  reason          String?
  approvedBy      String?
  effectiveDate   DateTime
  expiryDate      DateTime?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant       Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student      Student @relation(fields: [studentId], references: [userId], onDelete: SetNull)
  feeStructure FeeStructure? @relation(fields: [feeStructureId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([studentId])
  @@index([feeStructureId])
  @@index([isActive])
  @@index([effectiveDate])
}

// ═══════════════════════════════════════════════════
// 29. ADVERTISEMENT (Super Admin managed)
// ═══════════════════════════════════════════════════

model Advertisement {
  id                String           @id @default(uuid())
  title             String
  description       String           @db.Text
  imageUrl          String?
  linkUrl           String?
  targetAudience    AdTargetAudience @default(ALL)
  targetCities      Json?            // JSON array of city names
  targetSchoolTypes Json?            // JSON array of school types
  placement         AdPlacement      @default(DASHBOARD)
  startDate         DateTime
  endDate           DateTime
  priority          Int              @default(0)
  status            AdStatus         @default(PENDING)
  clickCount        Int              @default(0)
  impressionCount   Int              @default(0)
  createdBy         String
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  createdByUser User           @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  impressions   AdImpression[]

  @@index([status])
  @@index([startDate])
  @@index([endDate])
  @@index([targetAudience])
  @@index([placement])
  @@index([priority])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════
// 30. AD IMPRESSION
// ═══════════════════════════════════════════════════

model AdImpression {
  id              String           @id @default(uuid())
  adId            String
  userId          String
  tenantId        String
  studentId       String?
  impressionType  AdImpressionType
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  ad      Advertisement @relation(fields: [adId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant  Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student Student?      @relation(fields: [studentId], references: [userId], onDelete: SetNull)

  @@index([adId])
  @@index([userId])
  @@index([tenantId])
  @@index([studentId])
  @@index([impressionType])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════
// 31. SUBSCRIPTION PLAN (Platform billing)
// ═══════════════════════════════════════════════════

model PlatformPlan {
  id                String   @id @default(uuid())
  name              String   @unique
  priceMonthly      Decimal  @db.Decimal(10, 2)
  priceYearly       Decimal  @db.Decimal(10, 2)
  maxSchools        Int?
  maxUsersPerSchool Int?
  features          Json     // JSON array of feature strings
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  subscriptions SchoolSubscription[]

  @@index([isActive])
}

// ═══════════════════════════════════════════════════
// 32. SCHOOL SUBSCRIPTION
// ═══════════════════════════════════════════════════

model SchoolSubscription {
  id              String                   @id @default(uuid())
  tenantId        String
  planId          String
  status          SchoolSubscriptionStatus @default(TRIAL)
  startDate       DateTime
  endDate         DateTime
  amountPaid      Decimal?                 @db.Decimal(10, 2)
  paymentMethod   String?
  autoRenew       Boolean                  @default(false)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  tenant Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan   PlatformPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([planId])
  @@index([status])
  @@index([endDate])
}

// ═══════════════════════════════════════════════════
// 33. LOGIN HISTORY
// ═══════════════════════════════════════════════════

model LoginHistory {
  id            String       @id @default(uuid())
  userId        String
  ipAddress     String?
  userAgent     String?      @db.Text
  deviceType    String?
  location      String?
  status        LoginStatus
  failureReason String?      @db.Text
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════
// 34. AUDIT LOG
// ═══════════════════════════════════════════════════

model AuditLog {
  id            String       @id @default(uuid())
  tenantId      String
  userId        String?
  action        String
  entityType    String
  entityId      String
  oldValues     Json?
  newValues     Json?
  ipAddress     String?
  userAgent     String?      @db.Text
  severity      AuditSeverity @default(MEDIUM)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([entityId])
  @@index([severity])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════
// 35. GRADING SCHEME (per school grading formula)
// ═══════════════════════════════════════════════════

model GradingScheme {
  id            String   @id @default(uuid())
  tenantId      String
  name          String
  isDefault     Boolean  @default(false)
  grades        Json     // JSON array: [{grade, minPercentage, maxPercentage, gpa}]
  academicYear  String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  marks  Mark[]

  @@unique([tenantId, isDefault])
  @@index([tenantId])
  @@index([academicYear])
}

// ═══════════════════════════════════════════════════
// 36. SETTING (per-school configuration)
// ═══════════════════════════════════════════════════

model Setting {
  id            String           @id @default(uuid())
  tenantId      String
  key           String
  value         String           @db.Text
  category      SettingCategory  @default(GENERAL)
  description   String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId])
  @@index([category])
  @@index([key])
}
