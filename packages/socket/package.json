{
  "name": "@acadivo/socket",
  "version": "0.1.0",
  "private": true,
  "description": "Acadivo Socket.io real-time server with Redis adapter",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "jest --runInBand",
    "test:ci": "jest --runInBand --coverage --ci"
  },
  "dependencies": {
    "socket.io": "^4.7.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.2",
    "dotenv": "^16.4.0",
    "winston": "^3.13.0",
    "axios": "^1.7.0",
    "firebase-admin": "^12.1.0",
    "rate-limiter-flexible": "^5.0.0",
    "express": "^4.19.0",
    "@acadivo/shared": "*"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "ts-node": "^10.9.0",
    "nodemon": "^3.1.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.0",
    "@types/express": "^4.17.21",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.0",
    "ts-jest": "^29.1.0"
  }
}
